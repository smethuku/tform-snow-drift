-- GRANT PERMISSIONS
-- ==============================================================================

GRANT USAGE ON DATABASE mydatabase TO ROLE <your_drift_role>;
GRANT USAGE ON SCHEMA mydatabase.jump TO ROLE <your_drift_role>;
GRANT USAGE ON PROCEDURE mydatabase.jump.get_all_grants_of_roles(STRING) TO ROLE <your_drift_role>;

-- ==============================================================================
-- TESTING
-- ==============================================================================

-- Default: Production only (excludes D_* and T_*)
CALL get_all_grants_of_roles();

-- Explicit Production
CALL get_all_grants_of_roles('PROD');

-- Development only
CALL get_all_grants_of_roles('DEV');

-- Test environment only
CALL get_all_grants_of_roles('TEST');

-- All environments
CALL get_all_grants_of_roles('ALL');

-- Verify results
SELECT 
    CASE 
        WHEN role_name LIKE 'P_%' THEN 'Production'
        WHEN role_name LIKE 'D_%' THEN 'Development'
        WHEN role_name LIKE 'T_%' THEN 'Test'
        ELSE 'Other'
    END as environment,
    granted_to,
    COUNT(*) as grant_count
FROM TABLE(RESULT_SCAN(LAST_QUERY_ID()))
GROUP BY 
    CASE 
        WHEN role_name LIKE 'P_%' THEN 'Production'
        WHEN role_name LIKE 'D_%' THEN 'Development'
        WHEN role_name LIKE 'T_%' THEN 'Test'
        ELSE 'Other'
    END,
    granted_to
ORDER BY environment, granted_to;
